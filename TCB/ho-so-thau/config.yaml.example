# Personal configuration - copy to config.yaml and edit
# This file is git-ignored (personal to each team member)

author:
  name: "Your Name"
  role: "Technical Lead"
  team: "Solutions Architecture"

# Default model preferences (override per-phase if needed)
models:
  phase1_create: "Opus 4.6"
  phase1b_images: "Gemini 3 Pro"
  phase2_review: "GPT-5.2 High"
  phase3_fix: "Opus 4.6"
  quick_edit: "Opus 4.6 Fast"

# Company branding
branding:
  company_name: "Your Company"
  logo_path: "input/logo.png"  # optional

# Confluence integration (optional - for pre-fetch script)
confluence:
  site: "yourcompany.atlassian.net"  # Your Atlassian Cloud site
  default_space: "TEAM"  # Default space key
  # API token fallback (if not using Rovo MCP OAuth)
  # Only needed if using confluence_fetcher.py script
  # email: "your.email@company.com"
  # api_token: "your-api-token"
