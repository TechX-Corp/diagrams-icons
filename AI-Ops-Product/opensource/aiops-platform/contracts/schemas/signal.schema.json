{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiops-platform/schemas/signal.schema.json",
  "title": "Signal",
  "type": "object",
  "required": ["signal_id", "source_events", "entity_refs", "severity", "category", "fingerprint", "first_occurrence", "last_occurrence", "count"],
  "properties": {
    "signal_id": { "type": "string" },
    "source_events": { "type": "array", "items": { "type": "string" } },
    "entity_refs": { "type": "array", "items": { "type": "string" } },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "category": { "type": "string" },
    "fingerprint": { "type": "string" },
    "first_occurrence": { "type": "string", "format": "date-time" },
    "last_occurrence": { "type": "string", "format": "date-time" },
    "count": { "type": "integer", "minimum": 1 },
    "enrichments": { "type": "object" }
  }
}
