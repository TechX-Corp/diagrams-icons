{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiops-platform/schemas/rca_result.schema.json",
  "title": "RCAResult",
  "type": "object",
  "required": ["rca_id", "incident_id", "candidates", "algorithm_version", "computed_at", "confidence"],
  "properties": {
    "rca_id": { "type": "string" },
    "incident_id": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id", "score", "evidence_path", "explanation"],
        "properties": {
          "entity_id": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_path": { "type": "array", "items": { "type": "string" } },
          "explanation": { "type": "string" }
        }
      }
    },
    "algorithm_version": { "type": "string" },
    "computed_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
