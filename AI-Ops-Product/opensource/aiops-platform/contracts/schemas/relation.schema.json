{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiops-platform/schemas/relation.schema.json",
  "title": "Relation",
  "type": "object",
  "required": ["relation_id", "source_entity_id", "target_entity_id", "relation_type", "source_system", "discovered_at"],
  "properties": {
    "relation_id": { "type": "string" },
    "source_entity_id": { "type": "string" },
    "target_entity_id": { "type": "string" },
    "relation_type": {
      "type": "string",
      "enum": ["runs_on", "hosts", "connects_to", "depends_on", "member_of", "routes_through", "load_balances", "stores_data_in", "calls", "owns", "composed_of", "deploys_to", "affects"]
    },
    "source_system": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "discovered_at": { "type": "string", "format": "date-time" },
    "properties": { "type": "object" }
  }
}
