{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiops-platform/schemas/entity.schema.json",
  "title": "Entity",
  "description": "CDM entity representing an infrastructure or application component.",
  "type": "object",
  "required": ["canonical_id", "entity_type", "display_name", "source_refs", "first_seen", "last_seen", "lifecycle_state"],
  "properties": {
    "canonical_id": { "type": "string" },
    "entity_type": {
      "type": "string",
      "enum": ["host", "vm", "container", "pod", "namespace", "service", "application", "network_device", "network_interface", "load_balancer", "database", "cloud_resource", "business_service", "workload"]
    },
    "display_name": { "type": "string" },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_system", "native_id"],
        "properties": {
          "source_system": { "type": "string" },
          "native_id": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "attributes": { "type": "object" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "first_seen": { "type": "string", "format": "date-time" },
    "last_seen": { "type": "string", "format": "date-time" },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "lifecycle_state": { "type": "string", "enum": ["active", "decommissioned", "soft_deleted"] }
  }
}
