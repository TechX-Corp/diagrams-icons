{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiops-platform/schemas/incident.schema.json",
  "title": "Incident",
  "type": "object",
  "required": ["incident_id", "title", "severity", "status", "signals", "affected_entities", "created_at", "updated_at"],
  "properties": {
    "incident_id": { "type": "string" },
    "title": { "type": "string" },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "status": { "type": "string", "enum": ["open", "acknowledged", "investigating", "resolved", "closed"] },
    "signals": { "type": "array", "items": { "type": "string" } },
    "affected_entities": { "type": "array", "items": { "type": "string" } },
    "root_cause_candidates": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string" },
    "external_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["system", "ref_id"],
        "properties": {
          "system": { "type": "string" },
          "ref_id": { "type": "string" }
        }
      }
    }
  }
}
